FROM docker.io/library/debian:trixie-slim

RUN groupadd -r gobfd && useradd -r -g gobfd -s /usr/sbin/nologin gobfd \
    && apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG TARGETPLATFORM

COPY ${TARGETPLATFORM}/gobfd \
     ${TARGETPLATFORM}/gobfdctl \
     ${TARGETPLATFORM}/gobfd-haproxy-agent \
     ${TARGETPLATFORM}/gobfd-exabgp-bridge \
     /usr/local/bin/

USER gobfd:gobfd

EXPOSE 3784/udp 4784/udp 50051

ENTRYPOINT ["/usr/local/bin/gobfd"]
