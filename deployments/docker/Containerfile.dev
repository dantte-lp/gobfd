ARG GO_VERSION=1.26.2
ARG GOLANGCI_LINT_VERSION=v2.11.4
ARG GOVULNCHECK_VERSION=v1.2.0
ARG OSV_SCANNER_VERSION=v2.3.5
ARG NODE_MAJOR=22

FROM docker.io/golang:${GO_VERSION}-trixie AS dev

ARG GOLANGCI_LINT_VERSION
ARG GOVULNCHECK_VERSION
ARG OSV_SCANNER_VERSION
ARG NODE_MAJOR

ENV GOEXPERIMENT=goroutineleakprofile \
    GOFLAGS="-buildvcs=false" \
    GOCACHE=/tmp/go-cache \
    GOMODCACHE=/go/pkg/mod \
    NPM_CONFIG_UPDATE_NOTIFIER=false \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive

# Build tools and certificates
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    rm -f /etc/apt/apt.conf.d/docker-clean \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        ca-certificates \
        tzdata \
        make \
        bash \
        curl \
        jq \
        gnupg \
        python3 \
        python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Node.js (npm-based documentation linters and commitlint).
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && chmod a+r /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# buf CLI — protobuf toolchain
RUN go install github.com/bufbuild/buf/cmd/buf@latest

# protoc-gen-go — Go protobuf code generator
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest

# protoc-gen-connect-go — ConnectRPC code generator
RUN go install connectrpc.com/connect/cmd/protoc-gen-connect-go@latest

# golangci-lint v2 — strict linting
RUN go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION}

# govulncheck — Go vulnerability scanner (go.dev/doc/security/vuln)
RUN go install golang.org/x/vuln/cmd/govulncheck@${GOVULNCHECK_VERSION}

# osv-scanner — Google OSV vulnerability scanner (github.com/google/osv-scanner)
RUN go install github.com/google/osv-scanner/v2/cmd/osv-scanner@${OSV_SCANNER_VERSION}

# benchstat — statistical comparison of Go benchmarks
RUN go install golang.org/x/perf/cmd/benchstat@latest

# gotestsum — Go test runner with JUnit XML / JSON output
RUN go install gotest.tools/gotestsum@latest

# npm-based documentation linters.
RUN --mount=type=cache,target=/root/.npm \
    npm install -g \
        markdownlint-cli2@latest \
        cspell@latest \
        @commitlint/cli@latest \
        @commitlint/config-conventional@latest

# Python tooling: yamllint and JUnit XML to standalone HTML report.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --break-system-packages --no-cache-dir \
        yamllint \
        junit2html

# Module cache warm-up happens on first `go mod download`
WORKDIR /app
VOLUME /app

# Keep container running for exec commands
CMD ["sleep", "infinity"]
